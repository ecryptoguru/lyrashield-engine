{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "LyraShield Engine",
  "colors": {
    "primary": "#000000",
    "light": "#ffffff",
    "dark": "#000000"
  },
  "favicon": "/images/favicon-48.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Usage",
            "pages": ["usage/cli", "usage/scan-modes", "usage/instructions"]
          },
          {
            "group": "GPT-5.6 Endpoints",
            "pages": ["llm-providers/overview", "llm-providers/openai", "llm-providers/azure"]
          },
          {
            "group": "Tools",
            "pages": ["tools/overview", "tools/browser", "tools/proxy", "tools/terminal", "tools/sandbox"]
          },
          {
            "group": "Advanced",
            "pages": ["advanced/configuration", "advanced/skills", "contributing"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/ecryptoguru/lyrashield-engine",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ecryptoguru/lyrashield-engine"
    }
  },
  "fonts": {
    "family": "Geist",
    "heading": { "family": "Geist" },
    "body": { "family": "Geist" }
  },
  "appearance": {
    "default": "dark"
  },
  "description": "Controlled GPT-5.6 scan engine for LyraShield AI",
  "background": {
    "decoration": "grid"
  }
}
